
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "User account details including role and registration date.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["worker", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "role"]
    },
    "IncomeDna": {
      "title": "IncomeDna",
      "type": "object",
      "description": "AI-generated income profile for a worker.",
      "properties": {
        "userId": { "type": "string" },
        "peak_earning_hours": { "type": "array", "items": { "type": "string" } },
        "high_activity_days": { "type": "array", "items": { "type": "string" } },
        "expected_weekly_earnings": { "type": "number" },
        "avg_earnings_by_window": { "type": "array", "items": { "type": "object" } },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "UserPlan": {
      "title": "UserPlan",
      "type": "object",
      "description": "The insurance plan currently active for a user.",
      "properties": {
        "userId": { "type": "string" },
        "planId": { "type": "string" },
        "planName": { "type": "string" },
        "weekly_premium": { "type": "number" },
        "maxPayout": { "type": "number" },
        "startedAt": { "type": "string", "format": "date-time" },
        "is_active": { "type": "boolean" }
      }
    },
    "Claim": {
      "title": "Claim",
      "type": "object",
      "description": "Insurance claim filed by a worker.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "time_slot": { "type": "string" },
        "description": { "type": "string" },
        "claim_amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "DisruptionEvent": {
      "title": "DisruptionEvent",
      "type": "object",
      "description": "Details about a detected collective work disruption.",
      "properties": {
        "id": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "latitude": { "type": "number" },
        "longitude": { "type": "number" },
        "workersAffectedCount": { "type": "number" },
        "intensity": { "type": "number" },
        "riskLevel": { "type": "string", "enum": ["low", "medium", "high", "extreme"] },
        "aiSuggestion": { "type": "string" }
      }
    },
    "WeatherEvent": {
      "title": "WeatherEvent",
      "type": "object",
      "description": "Severe weather alerts impacting work.",
      "properties": {
        "city": { "type": "string" },
        "severity": { "type": "string" },
        "description": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/userProfiles/{userId}": {
      "schema": "#/backend/entities/UserProfile",
      "description": "User profile document."
    },
    "/income_dna/{userId}": {
      "schema": "#/backend/entities/IncomeDna",
      "description": "Worker income DNA profile."
    },
    "/user_plans/{userId}": {
      "schema": "#/backend/entities/UserPlan",
      "description": "Active insurance plan for the user."
    },
    "/claims/{claimId}": {
      "schema": "#/backend/entities/Claim",
      "description": "Insurance claims."
    },
    "/disruptionEvents/{eventId}": {
      "schema": "#/backend/entities/DisruptionEvent",
      "description": "Global disruption alerts."
    },
    "/weather_events/{eventId}": {
      "schema": "#/backend/entities/WeatherEvent",
      "description": "Severe weather alerts."
    }
  }
}
