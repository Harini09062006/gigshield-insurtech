
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Represents a gig worker or administrator.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "platform": { "type": "string" },
        "state": { "type": "string" },
        "city": { "type": "string" },
        "avg_hourly_earnings": { "type": "number" },
        "plan_id": { "type": "string" },
        "role": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "plan_activated_at": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "phone", "role"]
    },
    "SupportMessage": {
      "title": "SupportMessage",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "text": { "type": "string" },
        "sender": { "type": "string", "enum": ["user", "bot", "admin"] },
        "status": { "type": "string", "enum": ["open", "in-progress", "resolved"] },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "InsurancePlan": {
      "title": "InsurancePlan",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "weekly_premium": { "type": "number" },
        "max_payout": { "type": "number" },
        "description": { "type": "string" },
        "features": { "type": "array", "items": { "type": "string" } },
        "is_active": { "type": "boolean" }
      }
    },
    "Claim": {
      "title": "Claim",
      "type": "object",
      "properties": {
        "worker_id": { "type": "string" },
        "claim_number": { "type": "string" },
        "trigger_type": { "type": "string" },
        "dna_time_slot": { "type": "string" },
        "dna_hourly_rate": { "type": "number" },
        "hours_lost": { "type": "number" },
        "compensation": { "type": "number" },
        "status": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["phone"]
  },
  "firestore": {
    "users/{uid}": { "schema": "User", "description": "User profiles" },
    "insurance_plans/{id}": { "schema": "InsurancePlan", "description": "Insurance plans" },
    "claims/{id}": { "schema": "Claim", "description": "Insurance claims" },
    "support_messages/{id}": { "schema": "SupportMessage", "description": "Hybrid support system chat logs" },
    "income_dna/{uid}": { "schema": "IncomeDNA", "description": "Worker income patterns" },
    "weather_events/{id}": { "schema": "WeatherEvent", "description": "Weather triggers" },
    "disruption_zones/{id}": { "schema": "DisruptionZone", "description": "Live map zones" }
  }
}
