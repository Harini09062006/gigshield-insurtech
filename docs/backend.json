
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "User account details including role and registration date.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["worker", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "role"]
    },
    "IncomeDna": {
      "title": "IncomeDna",
      "type": "object",
      "description": "AI-generated income profile for a worker.",
      "properties": {
        "userId": { "type": "string" },
        "peak_earning_hours": { "type": "array", "items": { "type": "string" } },
        "high_activity_days": { "type": "array", "items": { "type": "string" } },
        "expected_weekly_earnings": { "type": "number" },
        "avg_earnings_by_window": { "type": "array", "items": { "type": "object" } },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "UserPlan": {
      "title": "UserPlan",
      "type": "object",
      "description": "The insurance plan currently active for a user.",
      "properties": {
        "userId": { "type": "string" },
        "planId": { "type": "string" },
        "planName": { "type": "string" },
        "weekly_premium": { "type": "number" },
        "maxPayout": { "type": "number" },
        "startedAt": { "type": "string", "format": "date-time" },
        "is_active": { "type": "boolean" }
      }
    },
    "Claim": {
      "title": "Claim",
      "type": "object",
      "description": "Insurance claim filed by a worker.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "time_slot": { "type": "string" },
        "description": { "type": "string" },
        "claim_amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/userProfiles/{userId}",
        "definition": { "schema": { "$ref": "#/backend/entities/UserProfile" } }
      },
      {
        "path": "/income_dna/{userId}",
        "definition": { "schema": { "$ref": "#/backend/entities/IncomeDna" } }
      },
      {
        "path": "/user_plans/{userId}",
        "definition": { "schema": { "$ref": "#/backend/entities/UserPlan" } }
      },
      {
        "path": "/claims/{claimId}",
        "definition": { "schema": { "$ref": "#/backend/entities/Claim" } }
      }
    ]
  }
}
