
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Specific rules for activity tracking
    match /activity/{id} {
      allow list: if request.auth != null;
      allow read, write: if request.auth != null;
    }

    // Specific rules for claims to support ordered queries with filtering
    match /claims/{claimId} {
      allow read: if request.auth != null && (
        resource.data.worker_id == request.auth.uid || 
        resource.data.userId == request.auth.uid
      );
      allow write: if request.auth != null;
    }

    // 🔓 FULLY OPEN RULES FOR OTHER COLLECTIONS DURING PROTOTYPE DEVELOPMENT
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
