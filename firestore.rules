rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the current user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper function to check if the current user is an administrator
    // Added exists() check to prevent permission errors during race conditions on sign-in
    function isAdmin() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // User profiles: Workers manage their own, admins manage all
    match /users/{uid} {
      allow read, write: if isSignedIn() && (request.auth.uid == uid || isAdmin());
    }
    
    // Claims: Parametric payout logs
    match /claims/{id} {
      allow create: if isSignedIn();
      
      // Optimize list/get for worker queries
      allow list, get: if isSignedIn() && (resource.data.worker_id == request.auth.uid || isAdmin());
      
      allow update, delete: if isAdmin();
    }

    // Support Messages: Hybrid bot/human chat logs
    match /support_messages/{id} {
      allow create: if isSignedIn();
      
      // Optimize for worker conversation streams
      allow list, get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }
    
    // Income DNA: AI-generated earning patterns
    match /income_dna/{uid} {
      allow read, write: if isSignedIn() && (request.auth.uid == uid || isAdmin());
    }
    
    // Weather Events & Disruption Zones: Public read, admin write
    match /weather_events/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /disruption_zones/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    // Insurance Plans: Configuration data
    match /insurance_plans/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}