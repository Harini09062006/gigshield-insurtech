rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY:
     * This ruleset implements a robust, ownership-based security model designed for an AI-powered gig worker 
     * insurance platform. It prioritizes "Authorization Independence" by using denormalized fields 
     * (like 'workerId' or 'userId') to ensure that every document can be secured without expensive recursive lookups.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // --- Collection Rules ---

    match /userProfiles/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if false;
    }

    match /userProfiles/{userId}/incomeDna/{dnaId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.workerId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.workerId == resource.data.workerId;
      allow delete: if isExistingOwner(userId);

      match /peakEarningHours/{peakEarningHourId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.workerId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.workerId == resource.data.workerId;
        allow delete: if isExistingOwner(userId);
      }

      match /earningsByTimeWindow/{earningsByTimeWindowId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.workerId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.workerId == resource.data.workerId;
        allow delete: if isExistingOwner(userId);
      }
    }

    match /userProfiles/{userId}/policies/{policyId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.workerId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.workerId == resource.data.workerId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rules for claims. Allows users to manage their own claims.
     * Denormalized 'userId' field is used for query authorization.
     */
    match /claims/{claimId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /disruptionEvents/{disruptionEventId} {
      allow get, list: if isSignedIn();
      allow create: if isAdmin();
      allow update, delete: if isAdmin() && resource != null;
    }

    match /admins/{adminId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update, delete: if false;
    }
  }
}