rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 🔥 PROTOTYPE UNIVERSAL ACCESS
    // This recursive wildcard rule ensures that all collections and documents 
    // are accessible for both read and write operations during development.
    // This resolved the 'Missing or insufficient permissions' errors when 
    // listing collections like 'claims' or 'users'.
    
    match /{document=**} {
      allow read, write: if true;
    }
    
    // Deployment trigger timestamp: 2024-05-24T16:00:00Z
  }
}