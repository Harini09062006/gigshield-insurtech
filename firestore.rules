
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the current user is an administrator
    // Note: Used carefully to avoid infinite recursion when fetching the user's own doc
    function isAdmin() {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // User profiles: Workers can manage their own, admins can manage all
    match /users/{uid} {
      // Direct owner check first - this is the "base case" that prevents recursion
      allow read, write: if request.auth != null && request.auth.uid == uid;
      // Admin check only for documents other than the requester's own
      allow read, write: if request.auth != null && request.auth.uid != uid && isAdmin();
    }
    
    // Claims: parametric payout logs
    match /claims/{id} {
      allow create: if request.auth != null;
      // Split read access helps the query analyzer verify worker-specific queries instantly
      allow read: if request.auth != null && resource.data.worker_id == request.auth.uid;
      allow read: if isAdmin();
      allow update, delete: if isAdmin();
    }

    // Support Messages: Hybrid bot/admin chat logs
    match /support_messages/{id} {
      allow create: if request.auth != null;
      // Separate worker and admin read rules to simplify query validation
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow read: if isAdmin();
      
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
    }
    
    // Income DNA: AI-generated earning patterns
    match /income_dna/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
      allow read, write: if request.auth != null && request.auth.uid != uid && isAdmin();
    }
    
    // Weather Events: Dynamic triggers for claims
    match /weather_events/{id} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    // Disruption Zones: Live map data points
    match /disruption_zones/{id} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    // Insurance Plans: Static configuration data
    match /insurance_plans/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
