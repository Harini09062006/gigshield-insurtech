rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Robust helper to check if user is admin
    function isAdmin() {
      return request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if isAdmin();
    }

    match /claims/{claimId} {
      // Allow workers to read their own and admins to read all
      allow read: if request.auth != null && (
        (resource != null && resource.data.worker_id == request.auth.uid) || isAdmin()
      );
      // Allow queries filtered by worker_id or admin listings
      allow list: if request.auth != null; 
      // Allow workers to create claims for the prototype simulation
      allow create: if request.auth != null;
      // Only admins can update/delete
      allow update, delete: if isAdmin();
    }

    match /insurance_plans/{planId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /disruption_zones/{zoneId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /income_dna/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if isAdmin();
    }
  }
}