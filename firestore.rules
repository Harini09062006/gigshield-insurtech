rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 🔥 PROTOTYPE ACCESS CONTROL
    // These rules are optimized for rapid prototyping and the "No-Auth" admin requirement.
    // They allow any user (authenticated or not) to read and write to the primary collections.
    
    match /users/{userId} {
      allow read, write: if true;
    }
    
    match /claims/{claimId} {
      allow read, write: if true;
    }
    
    match /support_messages/{messageId} {
      allow read, write: if true;
    }
    
    match /income_dna/{userId} {
      allow read, write: if true;
    }
    
    match /weather_events/{eventId} {
      allow read, write: if true;
    }
    
    match /disruption_zones/{zoneId} {
      allow read, write: if true;
    }
    
    match /insurance_plans/{planId} {
      allow read, write: if true;
    }

    // Default catch-all for potential subcollections or newly added paths
    match /{document=**} {
      allow read, write: if true;
    }
    
    // Rules deployment trigger timestamp: 2024-05-24T10:30:00Z
  }
}