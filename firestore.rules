
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the current user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper function to check if the current user is an administrator
    function isAdmin() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'worker') == 'admin';
    }

    // User profiles: Workers can manage their own, admins can manage all
    match /users/{uid} {
      // Owner check: Direct UID comparison
      allow read, write: if isSignedIn() && request.auth.uid == uid;
      // Admin check: only evaluate if not the owner to avoid unnecessary complexity
      allow read, write: if isSignedIn() && request.auth.uid != uid && isAdmin();
    }
    
    // Claims: parametric payout logs
    match /claims/{id} {
      allow create: if isSignedIn();
      // Split list/get rules to assist query analyzer with filtered queries
      allow list: if isSignedIn() && resource.data.worker_id == request.auth.uid;
      allow list: if isAdmin();
      allow get: if isSignedIn() && resource.data.worker_id == request.auth.uid;
      allow get: if isAdmin();
      allow update, delete: if isAdmin();
    }

    // Support Messages: Hybrid bot/admin chat logs
    match /support_messages/{id} {
      allow create: if isSignedIn();
      // Split list/get rules to assist query analyzer with filtered queries
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isAdmin();
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isAdmin();
      // Update allowed for owner (to resolve) or admin
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }
    
    // Income DNA: AI-generated earning patterns
    match /income_dna/{uid} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;
      allow read, write: if isAdmin();
    }
    
    // Weather Events: Dynamic triggers for claims
    match /weather_events/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    // Disruption Zones: Live map data points
    match /disruption_zones/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    // Insurance Plans: Static configuration data
    match /insurance_plans/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
