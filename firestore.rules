rules_version = '2';

/**
 * GigShield Protection - Security Rules (Prototyping Mode)
 *
 * PHILOSOPHY:
 * This ruleset enforces a strict user-ownership model using path-based authorization 
 * and structural segregation. It prioritizes high-security for authorization 
 * (who can access what) while maintaining maximum flexibility for data shapes 
 * to support rapid iteration.
 *
 * DATA STRUCTURE:
 * - /users/{userId}: Root profile for gig workers.
 * - /roles_admin/{adminId}: Dedicated collection for system administrators (Authorization Independence).
 * - /insurance_plans/{planId}: Publicly readable configuration for available plans.
 * - /weather_events & /disruption_zones: System-wide data for risk assessment/heatmaps.
 * - /users/{userId}/claims/{claimId}: Private, worker-specific claim history (Subcollection pattern).
 * - /users/{userId}/income_dna/{dnaId}: Private, worker-specific earning patterns.
 *
 * KEY SECURITY DECISIONS:
 * 1. ADMIN ROLE: Admin privileges are determined by the existence of a document in the 
 *    'roles_admin' collection. This avoids costly 'get' calls on user documents.
 * 2. PATH-BASED OWNERSHIP: Worker-specific data (claims, DNA) is nested under the 
 *    user's root path, making authorization checks simple and performance-optimized.
 * 3. DENORMALIZATION: Critical ownership fields (e.g., id, workerId) are validated 
 *    on creation to match the path but are otherwise not type-checked to allow prototyping.
 */

service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    /** @description Checks if the user is authenticated via Firebase Auth. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Combined check for ownership and document existence for destructive operations. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    /** @description Efficiently checks for admin privileges via existence in the roles_admin collection. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for the core User profile.
     * @path /users/{userId}
     * @allow get, list, create, update: if isOwner(userId);
     * @deny delete: if true; // Users cannot delete their own profiles via the client.
     * @principle Path-based ownership and self-creation validation.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isAdmin();
    }

    /**
     * @description Administrative role assignments.
     * @path /roles_admin/{adminId}
     * @allow read: if isSignedIn();
     * @deny write: if true; // Handled via Admin SDK/Console only for security.
     * @principle Segregated role collection for high-performance authorization.
     */
    match /roles_admin/{adminId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow write: if false; 
    }

    /**
     * @description Insurance plan configurations.
     * @path /insurance_plans/{planId}
     * @allow read: if true; // Publicly readable for the signup flow.
     * @deny write: if !isAdmin();
     * @principle Public read with admin-only writes.
     */
    match /insurance_plans/{planId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Global weather events triggering parametric payouts.
     * @path /weather_events/{eventId}
     * @allow read: if isSignedIn();
     * @deny write: if !isAdmin();
     * @principle Authenticated consumption of system-generated events.
     */
    match /weather_events/{eventId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Geographical risk zones for the interactive heatmap.
     * @path /disruption_zones/{zoneId}
     * @allow read: if isSignedIn();
     * @deny write: if !isAdmin();
     * @principle Real-time spatial data secured by authentication.
     */
    match /disruption_zones/{zoneId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Individual insurance claims nested under workers.
     * @path /users/{userId}/claims/{claimId}
     * @allow read: if isOwner(userId) || isAdmin();
     * @deny write: if !isAdmin(); // Claims are system-triggered based on parametric rules.
     * @principle Path-based isolation for private financial records.
     */
    match /users/{userId}/claims/{claimId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Personalized earning patterns generated by AI.
     * @path /users/{userId}/income_dna/{dnaId}
     * @allow read, write: if isOwner(userId) || isAdmin();
     * @principle Ownership-based access to sensitive personalized profiles.
     */
    match /users/{userId}/income_dna/{dnaId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) || isAdmin();
      allow update: if (isExistingOwner(userId) || isAdmin());
      allow delete: if isAdmin();
    }
  }
}