rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Basic rules for worker profiles
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin");
    }

    // Parametric Claims
    match /claims/{claimId} {
      allow list: if request.auth != null;
      allow get: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow read: if request.auth != null && (
        resource.data.worker_id == request.auth.uid || 
        resource.data.userId == request.auth.uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin"
      );
    }

    // Support Chat System
    match /support_messages/{id} {
      allow list: if request.auth != null;
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
    }

    match /support_tickets/{id} {
      allow list: if request.auth != null;
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
    }

    // DNA and Plans
    match /income_dna/{id} {
      allow read, write: if request.auth != null;
    }
    
    match /user_plans/{id} {
      allow read, write: if request.auth != null;
    }

    // 🔓 FALLBACK OPEN RULES FOR PROTOTYPE
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
