rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper to check if user is admin
    function isAdmin() {
      return request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if isAdmin();
    }

    match /claims/{claimId} {
      // Workers can only read their own claims. Admins can read all.
      allow read: if request.auth != null && (
        (resource != null && resource.data.worker_id == request.auth.uid) || isAdmin()
      );
      // Allow workers to list their own claims
      allow list: if request.auth != null && (
        request.query.limit <= 50 && 
        (isAdmin() || request.query.filters.worker_id == request.auth.uid)
      );
      // Workers can create claims for simulation.
      allow create: if request.auth != null && request.resource.data.worker_id == request.auth.uid;
      // Only admins can update/delete
      allow update, delete: if isAdmin();
    }

    match /insurance_plans/{planId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /disruption_zones/{zoneId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /income_dna/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if isAdmin();
    }
  }
}