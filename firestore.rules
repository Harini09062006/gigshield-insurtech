rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow public read and write access to all primary collections for the prototype.
    // This ensures that the No-Auth admin dashboard and worker components 
    // can sync data without permission errors during development.
    
    match /users/{userId} {
      allow read, write: if true;
    }
    
    match /claims/{claimId} {
      allow read, write: if true;
    }
    
    match /support_messages/{messageId} {
      allow read, write: if true;
    }
    
    match /income_dna/{userId} {
      allow read, write: if true;
    }
    
    match /weather_events/{eventId} {
      allow read, write: if true;
    }
    
    match /disruption_zones/{zoneId} {
      allow read, write: if true;
    }
    
    match /insurance_plans/{planId} {
      allow read, write: if true;
    }

    // Default rule for any other potential collections
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}