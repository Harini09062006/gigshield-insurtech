rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is an admin
    function isAdmin() {
      return request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if isAdmin();
    }

    match /claims/{claimId} {
      // Allow read (get and list) if the user owns the claim or is an admin.
      // For queries (list), Firestore rules act as a filter.
      allow read: if request.auth != null && (
        (resource != null && resource.data.worker_id == request.auth.uid) || isAdmin()
      );
      // Workers can create claims (for simulation).
      allow create: if request.auth != null;
      // Only admins can update or delete claims.
      allow update, delete: if isAdmin();
    }

    match /insurance_plans/{planId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /weather_events/{eventId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /disruption_zones/{zoneId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /income_dna/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if isAdmin();
    }
  }
}