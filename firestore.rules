rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the current user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper function to check if the current user is an administrator
    // Note: get() uses 1 read unit per evaluation. Use sparingly.
    // Refined to be more robust and recursion-safe.
    function isAdmin() {
      return isSignedIn() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // User profiles: Workers manage their own, admins manage all
    match /users/{uid} {
      // Direct owner check bypasses isAdmin() to prevent recursive rule evaluation
      allow read, write: if isSignedIn() && request.auth.uid == uid;
      // Admins can see all profiles
      allow read, write: if isAdmin();
    }
    
    // Claims: parametric payout logs
    match /claims/{id} {
      allow create: if isSignedIn();
      // Split list/get for better performance and deterministic query validation
      allow list: if isSignedIn() && (resource.data.worker_id == request.auth.uid || isAdmin());
      allow get: if isSignedIn() && (resource.data.worker_id == request.auth.uid || isAdmin());
      // Mutation is restricted to admins
      allow update, delete: if isAdmin();
    }

    // Support Messages: Smart bot/human chat logs
    match /support_messages/{id} {
      allow create: if isSignedIn();
      // Combine conditions for query analyzer efficiency
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      // Users can update status, admins have full management
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }
    
    // Income DNA: AI-generated earning patterns
    match /income_dna/{uid} {
      allow read, write: if isSignedIn() && (request.auth.uid == uid || isAdmin());
    }
    
    // Weather Events & Disruption Zones: Public read, admin write
    match /weather_events/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /disruption_zones/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    // Insurance Plans: Configuration data
    match /insurance_plans/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}