rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user has admin role
    function isAdmin() {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Helper to check ownership
    function isOwner(data) {
      return request.auth != null && (
        data.worker_id == request.auth.uid || 
        data.userId == request.auth.uid
      );
    }

    match /users/{uid} {
      // Users can read/write their own data. Admins can manage all users.
      allow read, write: if request.auth != null && (request.auth.uid == uid || isAdmin());
    }
    
    match /claims/{id} {
      // Allow read if user is the worker (owner) or an admin
      allow read: if request.auth != null && (isAdmin() || isOwner(resource.data));
      // Create: workers can file claims
      allow create: if request.auth != null;
      // Update/Delete: only admins can manage claims
      allow update, delete: if isAdmin();
    }
    
    match /income_dna/{uid} {
      allow read, write: if request.auth != null && (request.auth.uid == uid || isAdmin());
    }
    
    match /weather_events/{id} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    match /disruption_zones/{id} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    match /insurance_plans/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}