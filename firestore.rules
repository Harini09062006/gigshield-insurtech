
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && 
        get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.role == 'admin';
    }

    match /userProfiles/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) || isAdmin();
    }

    match /income_dna/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }

    match /user_plans/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }

    match /claims/{claimId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (request.query.limit <= 100 && (isAdmin() || (resource == null || resource.data.userId == request.auth.uid)));
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /insurance_plans/{planId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /disruptionEvents/{eventId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /weather_events/{eventId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /disruption_zones/{doc} {
      allow read: if isSignedIn();
    }

    match /heatmap_data/{doc} {
      allow read: if isSignedIn();
    }
  }
}
