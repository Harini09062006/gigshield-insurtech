
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAdmin() {
      return request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
      allow read, write: if isAdmin();
    }
    
    match /claims/{id} {
      allow create: if request.auth != null;
      // Split read access to help the query analyzer verify worker-specific queries
      allow read: if request.auth != null && resource.data.worker_id == request.auth.uid;
      allow read: if isAdmin();
      allow update, delete: if isAdmin();
    }

    match /support_messages/{id} {
      allow create: if request.auth != null;
      // Explicitly separate worker access from admin access
      allow read, update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow read, update: if isAdmin();
    }
    
    match /income_dna/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
      allow read, write: if isAdmin();
    }
    
    match /weather_events/{id} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    match /disruption_zones/{id} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    match /insurance_plans/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
