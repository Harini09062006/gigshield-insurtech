rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper to check if the user is an admin
    function isAdmin() {
      return request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Helper to check if the document belongs to the authenticated user
    function isOwner(userIdField) {
      return request.auth != null && request.auth.uid == userIdField;
    }

    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    match /claims/{claimId} {
      // Allow workers to read their own claims and admins to read all
      // Note: Queries must be filtered by worker_id for workers to pass the 'list' check
      allow read: if request.auth != null && (
        (resource != null && resource.data.worker_id == request.auth.uid) || isAdmin()
      );
      
      // Allow workers to create their own claims and admins to create any
      allow create: if request.auth != null && (
        (request.resource.data.worker_id == request.auth.uid) || isAdmin()
      );
      
      // Only admins can update or delete claims in this system
      allow update, delete: if isAdmin();
    }

    match /insurance_plans/{planId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /disruption_zones/{zoneId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /income_dna/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }
  }
}