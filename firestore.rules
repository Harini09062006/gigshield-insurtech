rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuth() { 
      return request.auth != null; 
    }
    function isOwner(uid) { 
      return request.auth.uid == uid; 
    }
    function isAdmin() {
      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    match /users/{uid} {
      allow read, write: if isOwner(uid) || isAdmin();
    }
    
    match /claims/{id} {
      allow read: if isAuth() && (
        (resource != null && resource.data.worker_id == request.auth.uid)
        || isAdmin()
      );
      allow create: if isAuth() && request.resource.data.worker_id == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /income_dna/{uid} {
      allow read, write: if isOwner(uid) || isAdmin();
    }

    match /weather_events/{id} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    match /disruption_zones/{id} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    match /insurance_plans/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /user_plans/{uid} {
      allow read, write: if isOwner(uid) || isAdmin();
    }
  }
}
