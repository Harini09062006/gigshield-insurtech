
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the current user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper function to check if the current user is an administrator
    // Includes an exists() check to prevent crashes if the user doc is being created
    function isAdmin() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'worker') == 'admin';
    }

    // User profiles: Workers can manage their own, admins can manage all
    match /users/{uid} {
      // Owner check: Direct UID comparison prevents recursion
      allow read, write: if isSignedIn() && request.auth.uid == uid;
      // Admin check: only evaluate for other users to prevent recursive calls
      allow read, write: if isSignedIn() && request.auth.uid != uid && isAdmin();
    }
    
    // Claims: parametric payout logs
    match /claims/{id} {
      allow create: if isSignedIn();
      // Combined list rule helps the query analyzer verify subset-safety
      allow list: if isSignedIn() && (resource.data.worker_id == request.auth.uid || isAdmin());
      allow get: if isSignedIn() && (resource.data.worker_id == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }

    // Support Messages: Hybrid bot/admin chat logs
    match /support_messages/{id} {
      allow create: if isSignedIn();
      // Combined list rule helps the query analyzer verify filtered queries
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }
    
    // Income DNA: AI-generated earning patterns
    match /income_dna/{uid} {
      allow read, write: if isSignedIn() && (request.auth.uid == uid || isAdmin());
    }
    
    // Weather Events: Dynamic triggers for claims
    match /weather_events/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    // Disruption Zones: Live map data points
    match /disruption_zones/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    // Insurance Plans: Static configuration data
    match /insurance_plans/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
