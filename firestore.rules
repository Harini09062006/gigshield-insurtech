
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the current user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper function to check if the current user is an administrator
    // Added exists check to prevent rule evaluation failure if doc is missing
    function isAdmin() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // User profiles: Workers manage their own, admins manage all
    match /users/{uid} {
      // Prioritize direct UID comparison to avoid recursion loops in isAdmin()
      allow read, write: if isSignedIn() && (request.auth.uid == uid || isAdmin());
    }
    
    // Claims: Parametric payout logs
    match /claims/{id} {
      allow create: if isSignedIn();
      
      // Split list rules for query analyzer efficiency. 
      // This ensures worker queries (filtered by worker_id) pass immediately.
      allow list: if isSignedIn() && resource.data.worker_id == request.auth.uid;
      allow list: if isAdmin();
      
      allow get: if isSignedIn() && resource.data.worker_id == request.auth.uid;
      allow get: if isAdmin();
      
      // Mutation restricted to admins
      allow update, delete: if isAdmin();
    }

    // Support Messages: Hybrid bot/human chat logs
    match /support_messages/{id} {
      allow create: if isSignedIn();
      
      // Allow workers to see their own messages, admins to see all
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      
      // Users can update status (resolved), admins have full management
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }
    
    // Income DNA: AI-generated earning patterns
    match /income_dna/{uid} {
      allow read, write: if isSignedIn() && (request.auth.uid == uid || isAdmin());
    }
    
    // Weather Events & Disruption Zones: Public read, admin write
    match /weather_events/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /disruption_zones/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    // Insurance Plans: Configuration data
    match /insurance_plans/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
