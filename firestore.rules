rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the current user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper function to check if the current user is an administrator
    function isAdmin() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // User profiles: Workers manage their own, admins manage all
    match /users/{uid} {
      // Relaxed for the "No-Auth" Admin Dashboard prototype
      allow read: if true; 
      allow write: if isSignedIn() && (request.auth.uid == uid || isAdmin());
    }
    
    // Claims: Parametric payout logs
    match /claims/{id} {
      // Relaxed for the "No-Auth" Admin Dashboard prototype
      allow read, update: if true;
      allow create: if isSignedIn() || true; // Allowed for simulation
      allow delete: if isAdmin();
    }

    // Support Messages: Hybrid bot/human chat logs
    match /support_messages/{id} {
      // Relaxed for the "No-Auth" Admin Dashboard prototype
      allow read, create, update: if true;
      allow delete: if isAdmin();
    }
    
    // Income DNA: AI-generated earning patterns
    match /income_dna/{uid} {
      allow read, write: if true; // Relaxed for dashboard overview
    }
    
    // Weather Events & Disruption Zones: Public read, admin write
    match /weather_events/{id} {
      allow read: if true;
      allow write: if isAdmin() || true;
    }
    
    match /disruption_zones/{id} {
      allow read: if true;
      allow write: if isAdmin() || true;
    }
    
    // Insurance Plans: Configuration data
    match /insurance_plans/{id} {
      allow read: if true;
      allow write: if isAdmin() || true;
    }
  }
}