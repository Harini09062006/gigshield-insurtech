rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
    }

    match /claims/{claimId} {
      // Allow workers to list only their own claims (filtered by worker_id or userId)
      // Allow admins to list all claims
      allow read: if isAuthenticated() && (
        (resource.data.worker_id == request.auth.uid || resource.data.userId == request.auth.uid) || 
        isAdmin()
      );
      
      // Allow workers to create their own claims and admins to create any
      allow create: if isAuthenticated() && (
        (request.resource.data.worker_id == request.auth.uid || request.resource.data.userId == request.auth.uid) || 
        isAdmin()
      );
      
      allow update, delete: if isAdmin();
    }

    match /insurance_plans/{planId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /disruption_zones/{zoneId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /income_dna/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
    }
  }
}