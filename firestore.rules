rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the current user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper function to check if the current user is an administrator
    // Note: get() uses 1 read unit per evaluation. Use sparingly.
    function isAdmin() {
      return isSignedIn() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // User profiles: Workers manage their own, admins manage all
    match /users/{uid} {
      // Allow user to read/write their own document without calling isAdmin() to avoid recursion
      allow read, write: if isSignedIn() && request.auth.uid == uid;
      // Allow admins to access all user documents
      allow read, write: if isAdmin();
    }
    
    // Claims: parametric payout logs
    match /claims/{id} {
      allow create: if isSignedIn();
      // Split list/get for better query analyzer performance
      allow list: if isSignedIn() && resource.data.worker_id == request.auth.uid;
      allow get: if isSignedIn() && resource.data.worker_id == request.auth.uid;
      // Admins have full access
      allow list, get, update, delete: if isAdmin();
    }

    // Support Messages: Smart bot/human chat logs
    match /support_messages/{id} {
      allow create: if isSignedIn();
      // Split list/get to help the query analyzer verify filtered queries
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      // Admins have full access to management
      allow list, get, update, delete: if isAdmin();
    }
    
    // Income DNA: AI-generated earning patterns
    match /income_dna/{uid} {
      allow read, write: if isSignedIn() && (request.auth.uid == uid || isAdmin());
    }
    
    // Weather Events & Disruption Zones: Public read, admin write
    match /weather_events/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /disruption_zones/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    // Insurance Plans: Configuration data
    match /insurance_plans/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
